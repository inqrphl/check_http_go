    "version": "0.2.0",
    "configurations": [
        {
            "name": "check_http --hostname example.com -v",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "program": "${workspaceFolder}/check_http.linux.amd64",
            "args": [
                "--hostname",
                "example.com",
                "-v"
            ],
            "env": {},
            "preLaunchTask": "build linux-amd64 debug"
        },
        {
            "name": "check_http --hostname mail.google.com -v --timeout 1000000s",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "program": "${workspaceFolder}/check_http.linux.amd64",
            "args": [
                "--hostname",
                "mail.google.com",
                "-v",
                "--timeout",
